/*
 * Totem keymap — 44 positions
 *   0-37 : keyboard keys (left 0-18, right 19-37, counting by matrix map order)
 *  38-43 : trackball buttons (row 4, cols 0-5)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    macros {
        simple371: simple371 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp S &kp I &kp M &kp P &kp L &kp E &kp N3 &kp N7 &kp N1>;
        };

        open_dq: open_dq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings =
                <&macro_tap>, <&kp KP_NUM>,
                <&macro_press>, <&kp LALT>,
                <&macro_tap>, <&kp KP_N0 &kp KP_N1 &kp KP_N4 &kp KP_N7>,
                <&macro_release>, <&kp LALT>,
                <&macro_tap>, <&kp KP_NUM>;
        };

        close_dq: close_dq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings =
                <&macro_tap>, <&kp KP_NUM>,
                <&macro_press>, <&kp LALT>,
                <&macro_tap>, <&kp KP_N0 &kp KP_N1 &kp KP_N4 &kp KP_N8>,
                <&macro_release>, <&kp LALT>,
                <&macro_tap>, <&kp KP_NUM>;
        };

        open_sq: open_sq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings =
                <&macro_tap>, <&kp KP_NUM>,
                <&macro_press>, <&kp LALT>,
                <&macro_tap>, <&kp KP_N0 &kp KP_N1 &kp KP_N4 &kp KP_N5>,
                <&macro_release>, <&kp LALT>,
                <&macro_tap>, <&kp KP_NUM>;
        };

        close_sq: close_sq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings =
                <&macro_tap>, <&kp KP_NUM>,
                <&macro_press>, <&kp LALT>,
                <&macro_tap>, <&kp KP_N0 &kp KP_N1 &kp KP_N4 &kp KP_N6>,
                <&macro_release>, <&kp LALT>,
                <&macro_tap>, <&kp KP_NUM>;
        };
    };

    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <190>;
            quick-tap-ms = <0>;
            flavor = "tap-preferred";
            require-prior-idle-ms = <190>;
            bindings = <&kp>, <&kp>;
        };

        hs: homerow_shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <190>;
            quick-tap-ms = <0>;
            flavor = "balanced";
            require-prior-idle-ms = <0>;
            bindings = <&kp>, <&kp>;
        };

        mm_space_ralt: mod_morph_space_ralt {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp SPACE>, <&kp DEL>;
            mods = <(MOD_RSFT)>;
        };

        mm_r_alt_f4: mod_morph_r_alt_f4 {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp R>, <&kp LA(F4)>;
            mods = <(MOD_LALT)>;
        };

        mm_dot_qmark: mod_morph_dot_qmark {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp DOT>, <&kp FSLH>;
            mods = <(MOD_RSFT)>;
            keep-mods = <(MOD_RSFT)>;
        };

        mm_esc_enter: mod_morph_esc_enter {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp ESC>, <&kp ENTER>;
            mods = <(MOD_LSFT)>;
        };

        mt_lgui_esc: mt_lgui_esc {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <0>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&mm_esc_enter>;
        };

        mm_bspc_lsft: mod_morph_bspc_lsft {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp BSPC>;
            mods = <(MOD_LSFT)>;
        };

        mm_enter_alttab: mod_morph_enter_alttab {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&mm_bspc_lsft>, <&kp TAB>;
            mods = <(MOD_LALT|MOD_RALT)>;
            keep-mods = <(MOD_LALT|MOD_RALT)>;
        };

        lt_mm: lt_mod_morph {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <170>;
            quick-tap-ms = <0>;
            flavor = "tap-preferred";
            bindings = <&mo>, <&mm_enter_alttab>;
        };

        td_h_caps: tap_dance_h_caps {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp H>, <&kp CAPS>;
        };

        td_j_ralt: tap_dance_j_ralt {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp J>, <&kp RALT>;
        };

        td_u_layer1: td_u_layer1 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp U>, <&tog 1>;
        };

        td_y_hanja: td_y_hanja {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp Y>, <&kp LANG_HANJA>;
        };

        td_i_layer2: td_i_layer2 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp I>, <&tog 2>;
        };

        td_quoute: td_quoute {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <210>;
            bindings = <&kp SINGLE_QUOTE>, <&kp DOUBLE_QUOTES>;
        };

        mm_space_shift: mod_morph_space_shift {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&mm_space_ralt>, <&kp DEL>;
            mods = <(MOD_RSFT)>;
        };

        mm_ralt_perm_del: mod_morph_ralt_perm_del {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp RALT>, <&kp LS(DEL)>;
            mods = <(MOD_RSFT)>;
        };

        mm_lt_bspc_lsft: mm_lt_bspc_lsft {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&lt_mm 2 0>, <&mm_bspc_lsft>;
            mods = <(MOD_LSFT)>;
        };

        mm_alt_v_as_s: mm_alt_v_as_s {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp V>, <&kp S>;
            mods = <(MOD_LALT)>;
            keep-mods = <(MOD_LALT)>;
        };

        lth: layer_tap_hold {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            hold-while-undecided;
            tapping-term-ms = <150>;
            bindings = <&mo>, <&mkp>;
        };

        lth_kp: layer_tap_hold_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            hold-while-undecided;
            tapping-term-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        tbl_btn1: tbl_btn1 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <250>;
            bindings = <&kp LC(C)>, <&tog 5>;
        };


        tbl_rclk: tbl_rclk {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <250>;
            bindings = <&lth 6 RCLK>, <&tog 7>;
        };
    };

    combos {
        compatible = "zmk,combos";

        combo_kl_ralt {
            timeout-ms = <75>;
            key-positions = <17 18>;
            bindings = <&kp RALT>;
        };

        combo_mcomma_excl {
            timeout-ms = <75>;
            key-positions = <27 28>;
            bindings = <&kp EXCL>;
        };

        combo_commadot_qmark {
            timeout-ms = <75>;
            key-positions = <28 29>;
            bindings = <&kp QMARK>;
        };

        combo_cv_paste {
            timeout-ms = <75>;
            key-positions = <23 24>;
            bindings = <&kp LC(V)>;
        };

        combo_xc_copy {
            timeout-ms = <75>;
            key-positions = <22 23>;
            bindings = <&kp LC(C)>;
        };

        combo_zx_cut {
            timeout-ms = <100>;
            key-positions = <21 22>;
            bindings = <&kp LC(X)>;
        };

        combo_xv_enter {
            timeout-ms = <75>;
            key-positions = <22 24>;
            bindings = <&kp ENTER>;
        };

        combo_vb_enter {
            timeout-ms = <75>;
            key-positions = <24 25>;
            bindings = <&kp ENTER>;
        };

        combo_nm_tilde {
            timeout-ms = <75>;
            key-positions = <26 27>;
            bindings = <&kp TILDE>;
        };

        combo_mdot_del {
            timeout-ms = <75>;
            key-positions = <27 29>;
            bindings = <&kp DEL>;
        };

        combo_wr_ralt {
            timeout-ms = <75>;
            key-positions = <1 3>;
            bindings = <&kp RALT>;
        };

        combo_we_back {
            timeout-ms = <75>;
            key-positions = <1 2>;
            bindings = <&kp C_AC_BACK>;
        };

        combo_er_forward {
            timeout-ms = <75>;
            key-positions = <2 3>;
            bindings = <&kp C_AC_FORWARD>;
        };

        /* Trackball combos */
        combo_tb_close {
            timeout-ms = <75>;
            key-positions = <38 39>;
            bindings = <&kp LA(F4)>;
        };

        combo_tb_close34 {
            timeout-ms = <75>;
            key-positions = <40 41>;
            bindings = <&kp LC(W)>;
        };

        combo_tb_refresh {
            timeout-ms = <75>;
            key-positions = <41 42>;
            bindings = <&kp F5>;
        };

        combo_tb_enter {
            timeout-ms = <75>;
            key-positions = <41 43>;
            bindings = <&kp ENTER>;
        };

        combo_tb_bootloader {
            timeout-ms = <75>;
            key-positions = <39 40>;
            bindings = <&bootloader>;
        };

        combo_ble_reset {
            timeout-ms = <150>;
            key-positions = <38 39 40 41>;
            bindings = <&bt BT_CLR>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            bindings = <
        &kp Q  &kp W       &kp E         &mm_r_alt_f4   &kp T           &td_y_hanja  &td_u_layer1  &td_i_layer2     &kp O          &kp P
        &kp A  &hm LALT S  &hm LCTRL D   &hm LSHIFT F   &kp G           &td_h_caps   &td_j_ralt    &kp K            &kp L          &kp SEMI
&tog 5  &kp Z  &kp X       &kp C         &mm_alt_v_as_s &kp B           &kp N        &kp M         &kp COMMA        &mm_dot_qmark  &mt RSHIFT FSLH  &tog 1
                            &mt_lgui_esc LGUI 0  &mm_lt_bspc_lsft  &mt LALT TAB  &mm_ralt_perm_del  &lt 1 ENTER  &mm_space_shift
        &tbl_btn1  &kp LC(V)  &lth_kp 8 C_AC_FORWARD  &lth_kp 9 C_AC_BACK  &mkp LCLK  &tbl_rclk
            >;
        };

        layer_1 {
            bindings = <
            &kp EXCL   &kp AT    &kp HASH  &kp DLLR       &kp PRCNT           &kp HOME  &kp PG_UP  &kp UP           &kp PG_DN  &kp PSCRN
            &kp CARET  &kp AMPS  &kp STAR  &kp LPAR       &kp RPAR            &kp END   &kp LEFT   &kp DOWN         &kp RIGHT  &kp INS
&to 2       &kp Z      &kp X     &kp C     &kp LESS_THAN  &kp GREATER_THAN    &mkp LCLK &kp C_AC_BACK  &kp C_AC_FORWARD  &kp DOT  &kp FSLH  &tog 1
                                 &mt_lgui_esc LGUI 0  &mm_lt_bspc_lsft  &mt LALT TAB  &kp DEL  &kp ENTER  &mm_space_shift
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        layer_2 {
            bindings = <
        &kp LG(N1)   &kp LG(N2)  &kp LG(N3)  &kp LG(N4)  &kp LG(N5)   &kp UNDER  &kp N7  &kp N8  &kp N9  &kp EQUAL
        &open_dq     &close_dq   &open_sq    &close_sq   &td_quoute   &kp MINUS  &kp N4  &kp N5  &kp N6  &kp PLUS
&tog 2  &kp LC(F10)  &kp F7      &kp F5      &kp F2      &simple371   &kp N0     &kp N1  &kp N2  &kp N3  &kp DOT  &to 1
                                 &mt_lgui_esc LGUI 0  &mm_bspc_lsft  &mt LALT TAB  &kp DEL  &lt 1 ENTER  &mm_space_shift
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        device {
            bindings = <
       &none       &kp C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC  &none             &none    &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
       &kp K_MUTE  &kp C_VOLUME_DOWN     &kp C_VOLUME_UP       &kp C_PLAY_PAUSE  &none    &none         &none         &none         &none         &none
&none  &none       &none                 &none                 &none             &none    &none         &none         &none         &none         &none         &bt BT_CLR
                                         &none                 &none             &none    &none         &none         &none
        &none  &none  &none  &none  &none  &none
            >;
        };

        tbl_scroll_m {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        tbl_scroll_h {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        tbl_snipe {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        tbl_snipe_h {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        tbl_nav_3h {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &trans  &kp LC(TAB)  &trans  &trans
            >;
        };

        tbl_nav_4h {
            bindings = <
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans
&trans  &trans &trans &trans &trans &trans  &trans &trans &trans &trans &trans  &trans
                      &trans &trans &trans  &trans &trans &trans
        &trans  &trans  &kp LC(LS(TAB))  &trans  &trans  &trans
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        device {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
